---
const nav = [
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' }
];
---
<header class="sticky top-0 z-50 border-b border-white/10 bg-ink/80 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8" aria-label="Main navigation">
    <a href="/" class="flex items-center gap-3 font-semibold tracking-tight text-white">
      <span class="flex h-9 w-9 items-center justify-center rounded-xl border border-signal/30 bg-signal/10 text-signal">Cx</span>
      <span>CxRomos</span>
    </a>
    <div class="hidden items-center gap-7 md:flex">
      {nav.map((item) => <a class="text-sm text-slate-300 transition hover:text-white" href={item.href}>{item.label}</a>)}
    </div>
    <a href="mailto:danijel@cxromos.com" class="hidden rounded-full border border-line px-4 py-2 text-sm font-medium text-slate-200 transition hover:border-signal/70 hover:text-white md:inline-flex">
      danijel@cxromos.com
    </a>
    <button
      id="nav-toggle"
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-line text-slate-200 transition hover:border-signal/70 hover:text-white md:hidden"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Toggle navigation menu"
    >
      <svg id="nav-icon-open" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
      <svg id="nav-icon-close" viewBox="0 0 24 24" class="hidden h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </nav>
  <div id="mobile-nav" hidden class="border-t border-white/10 px-6 pb-6 pt-2 md:hidden">
    <div class="flex flex-col">
      {nav.map((item) => <a class="border-b border-white/5 py-3 text-slate-200 transition hover:text-white" href={item.href}>{item.label}</a>)}
      <a href="mailto:danijel@cxromos.com" class="py-3 font-medium text-signal hover:text-sky-300">danijel@cxromos.com</a>
    </div>
  </div>
</header>
<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('nav-icon-open');
  const iconClose = document.getElementById('nav-icon-close');

  toggle?.addEventListener('click', () => {
    if (!toggle || !menu) return;
    const nowHidden = menu.toggleAttribute('hidden');
    toggle.setAttribute('aria-expanded', String(!nowHidden));
    iconOpen?.classList.toggle('hidden', !nowHidden);
    iconClose?.classList.toggle('hidden', nowHidden);
  });
</script>
