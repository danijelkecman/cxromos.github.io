---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}
const { eyebrow, title, description } = Astro.props;
---
<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  {eyebrow && <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-signal">{eyebrow}</p>}
  <h2 class="max-w-4xl text-3xl font-semibold tracking-tight text-white md:text-5xl text-balance">{title}</h2>
  {description && <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">{description}</p>}
  <div class="mt-10">
    <slot />
  </div>
</section>
