---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---
<BaseLayout title="Page not found — CxRomos" description="The page you were looking for does not exist.">
  <section class="mx-auto max-w-7xl px-6 py-32 lg:px-8">
    <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-signal">404</p>
    <h1 class="max-w-3xl text-5xl font-semibold tracking-tight text-white md:text-6xl text-balance">This route has no destination.</h1>
    <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">The page you were looking for does not exist or has moved.</p>
    <div class="mt-10 flex flex-col gap-4 sm:flex-row">
      <Button href="/">Back to homepage</Button>
      <Button href="/contact" variant="secondary">Contact us</Button>
    </div>
  </section>
</BaseLayout>
