---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import signal from '../data/operational-signal.json';
import { scaleSeries, smoothPath, waypointIndices, peakIndices, yAxisTicks } from '../lib/chart';

const values = signal.points.map((p) => p.v);
const pts = scaleSeries(values, 60, 477, 55, 205);
const pathD = smoothPath(pts);
const waypoints = waypointIndices(pts.length, 5);
const peaks = peakIndices(values, 3, waypoints);
const yTicks = yAxisTicks(values); // [min, mid, max] rendered bottom to top
const yTickYs = [205, 130, 55];
const xTicks = waypointIndices(pts.length, 5);
---
<BaseLayout>
  <section class="grid-bg relative overflow-hidden">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 py-24 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-32">
      <div>
        <p class="mb-5 inline-flex rounded-full border border-signal/30 bg-signal/10 px-4 py-2 text-sm font-medium text-signal">
          AI-native operational intelligence
        </p>
        <h1 class="text-balance text-5xl font-semibold tracking-tight text-white md:text-7xl">
          Software for real-time decisions where mistakes are expensive.
        </h1>
        <p class="mt-7 max-w-2xl text-xl leading-8 text-slate-300">
          CxRomos builds AI-native operational software for aviation, routing, geospatial systems, and high-consequence decision workflows.
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <Button href="/contact">Discuss a project</Button>
          <Button href="/work" variant="secondary">View focus areas</Button>
        </div>
      </div>
      <div class="relative rounded-[2rem] border border-white/10 bg-panel/80 p-6 shadow-soft">
        <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-signal/20 blur-3xl"></div>
        <div class="space-y-4">
          <div class="rounded-2xl border border-line bg-ink/70 p-5">
            <div class="flex items-center justify-between gap-4 text-sm text-slate-400">
              <span>{signal.label}</span>
              <span class="whitespace-nowrap text-signal">live · {signal.updated}</span>
            </div>
            <svg viewBox="0 0 520 260" class="mt-4 h-auto w-full" role="img" aria-label={`${signal.label} — ${signal.unit}. Data from ${signal.source}.`}>
              <defs>
                <linearGradient id="route" x1="0" x2="1" y1="0" y2="0">
                  <stop stop-color="#38bdf8" />
                  <stop offset="1" stop-color="#f97316" />
                </linearGradient>
              </defs>
              <g stroke="#1f3148" stroke-width="1">
                {yTickYs.map((y) => <path d={`M60 ${y}H477`} />)}
                {xTicks.map((i) => <path d={`M${pts[i].x} 55V212`} />)}
              </g>
              <g fill="#64748b" font-size="11" text-anchor="end">
                {yTicks.map((label, i) => <text x="52" y={yTickYs[i] + 4}>{label}</text>)}
              </g>
              <g fill="#64748b" font-size="11" text-anchor="middle">
                {xTicks.map((i) => <text x={pts[i].x} y="232">{signal.points[i].t}</text>)}
              </g>
              <path d={pathD} fill="none" stroke="url(#route)" stroke-width="5" stroke-linecap="round" />
              <g fill="#f97316">
                {peaks.map((i) => <circle cx={pts[i].x} cy={pts[i].y} r="6" />)}
              </g>
              <g fill="#38bdf8">
                {waypoints.map((i, n) => (
                  <circle cx={pts[i].x} cy={pts[i].y} r={n === 0 || n === waypoints.length - 1 ? 9 : 7} />
                ))}
              </g>
            </svg>
            <p class="mt-2 text-xs text-slate-500">{signal.unit} · {signal.source}</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-3">
            <div class="rounded-2xl border border-line bg-ink/70 p-4"><div class="text-2xl font-semibold text-white">Graph</div><p class="mt-1 text-sm text-slate-400">routing logic</p></div>
            <div class="rounded-2xl border border-line bg-ink/70 p-4"><div class="text-2xl font-semibold text-white">AI</div><p class="mt-1 text-sm text-slate-400">decision support</p></div>
            <div class="rounded-2xl border border-line bg-ink/70 p-4"><div class="text-2xl font-semibold text-white">Ops</div><p class="mt-1 text-sm text-slate-400">real-time systems</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Section eyebrow="The problem" title="Operational teams are drowning in fragmented data." description="Routes, constraints, alerts, weather, documents, system events, and human judgment are often split across tools that were never designed to reason together. The usual answer is another tool. But automating a fragmented process only delivers the chaos faster.">
    <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-8 text-2xl font-medium leading-10 text-white shadow-soft">
      The next generation of software will not be dashboards. It will be decision infrastructure — systems that think with operators, not just report to them.
    </div>
  </Section>

  <Section eyebrow="How we think" title="Automation starts in the thinking, not the tooling." description="Tools amplify whatever logic sits behind them. Before we write software, we map how the operation actually decides: what repeats, what connects, what matters under pressure.">
    <div class="grid gap-6 sm:grid-cols-2">
      <Card title="Clarity before code">We model the decision logic first — inputs, constraints, ownership of the next action. Once the system is understood, the software almost designs itself.</Card>
      <Card title="Systems, not tasks">Task thinking asks how to do something faster. System thinking asks why it exists and how it fits everything else. We optimise the loop, not the click.</Card>
      <Card title="Quiet by design">Every automation must reduce noise, not add layers. Fewer alerts, fewer handoffs, less cognitive load — the clearest proof a system works is the silence around it.</Card>
      <Card title="Extend judgment, never replace it">Machines execute; humans design the logic and own the call. We build software that compresses context for the person deciding — with guardrails, not black boxes.</Card>
    </div>
  </Section>

  <Section eyebrow="What we build" title="Systems that convert complexity into trusted operational decisions.">
    <div class="grid gap-6 md:grid-cols-3">
      <Card title="Real-time operational systems">Routing, monitoring, alerts, mobile workflows, event-driven infrastructure, and internal tools that operators can trust under pressure.</Card>
      <Card title="AI-assisted workflows">LLM interfaces over structured data, document intelligence, operator copilots, and decision support with explicit guardrails.</Card>
      <Card title="Aviation & geospatial software">Flight routing, waypoint logic, spatial search, map systems, risk overlays, and graph-based operational intelligence.</Card>
    </div>
  </Section>

  <Section eyebrow="Technical proof" title="Built on engineering, not theater.">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {['Swift / Objective-C / iOS', 'Android', 'Fullstack', 'Cloud systems', 'System Design', 'Real-time Systems', 'AI / LLM workflows', 'Enterprise integration'].map((item) => (
        <div class="rounded-2xl border border-line bg-panel/70 p-5 font-medium text-slate-100">{item}</div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Current focus" title="AI-native software for aviation, operational intelligence, and high-consequence decision systems." description="CxRomos works where software has to be explainable, fast, integrated, and useful to humans making real decisions.">
    <div class="flex flex-col gap-4 sm:flex-row">
      <Button href="/work">View focus areas</Button>
      <Button href="/about" variant="secondary">About the founder</Button>
    </div>
  </Section>
</BaseLayout>
