---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---
<BaseLayout title="Contact — CxRomos">
  <section class="mx-auto max-w-4xl px-6 py-28 lg:px-8">
    <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-signal">Contact</p>
    <h1 class="text-5xl font-semibold tracking-tight text-white md:text-6xl">Discuss a serious technical problem.</h1>
    <p class="mt-6 text-xl leading-8 text-slate-300">For technical partnerships, product development, aviation/geospatial systems, operational intelligence, or advisory work.</p>
    <div class="mt-10">
      <Button href="mailto:danijel@cxromos.com">danijel@cxromos.com</Button>
    </div>
  </section>
</BaseLayout>
