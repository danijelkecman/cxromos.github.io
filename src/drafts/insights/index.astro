---
import BaseLayout from '../../layouts/BaseLayout.astro';
const posts = Object.entries(import.meta.glob('../../content/insights/*.md', { eager: true })).map(([path, post]: any) => ({
  ...post,
  slug: path.split('/').pop()?.replace(/\.md$/, '')
}));
const sorted = posts.sort((a: any, b: any) => String(b.frontmatter.date).localeCompare(String(a.frontmatter.date)));
---
<BaseLayout title="Insights — CxRomos" description="Technical notes from CxRomos on AI-native operational intelligence, aviation software, graph routing, and real-time systems.">
  <section class="mx-auto max-w-5xl px-6 py-24 lg:px-8">
    <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-signal">Insights</p>
    <h1 class="text-5xl font-semibold tracking-tight text-white md:text-6xl">Technical notes for operational intelligence.</h1>
    <div class="mt-12 grid gap-6">
      {sorted.map((post: any) => (
        <a href={`/insights/${post.slug}`} class="block rounded-3xl border border-white/10 bg-white/[0.04] p-7 transition hover:border-signal/50 hover:bg-white/[0.06]">
          <div class="text-sm text-slate-400">{post.frontmatter.date}</div>
          <h2 class="mt-2 text-2xl font-semibold text-white">{post.frontmatter.title}</h2>
          <p class="mt-3 leading-7 text-slate-300">{post.frontmatter.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
