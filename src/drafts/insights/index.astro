---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('insights')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<BaseLayout title="Insights — CxRomos" description="Technical notes from CxRomos on AI-native operational intelligence, aviation software, graph routing, and real-time systems.">
  <section class="mx-auto max-w-5xl px-6 py-24 lg:px-8">
    <p class="mb-3 text-sm font-semibold uppercase tracking-[0.24em] text-signal">Insights</p>
    <h1 class="text-5xl font-semibold tracking-tight text-white md:text-6xl">Technical notes for operational intelligence.</h1>
    <div class="mt-12 grid gap-6">
      {posts.map((post) => (
        <a href={`/insights/${post.id}`} class="block rounded-3xl border border-white/10 bg-white/[0.04] p-7 transition hover:border-signal/50 hover:bg-white/[0.06]">
          <div class="text-sm text-slate-400">{formatDate(post.data.date)}</div>
          <h2 class="mt-2 text-2xl font-semibold text-white">{post.data.title}</h2>
          <p class="mt-3 leading-7 text-slate-300">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
